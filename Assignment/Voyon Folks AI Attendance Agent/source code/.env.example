# ─── Voyon HRMS connection ────────────────────────────────────────────────────
HRMS_BASE_URL=https://localhost:44360
HRMS_LOGIN_PATH=/m/api/Login/LoginUser
HRMS_SSL_VERIFY=false

# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ─── Agent ────────────────────────────────────────────────────────────────────
SYSTEM_PROMPT_FILE=systemprompt.txt

# ─── Evaluation tests (optional) ─────────────────────────────────────────────
# Used by: python -m pytest tests/test_evaluation_dataset.py -v --run-live-hrms
EVAL_HRMS_USERNAME=
EVAL_HRMS_PASSWORD=

# ─── Application ──────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-this-to-a-random-secret-key-in-production
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=false
